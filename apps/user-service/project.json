{
  "name": "user-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/user-service/src",
  "projectType": "application",
  "tags": ["scope:service", "type:user"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/user-service",
        "main": "apps/user-service/src/main.ts",
        "tsConfig": "apps/user-service/tsconfig.app.json",
        "assets": [
          "apps/user-service/prisma/schema.prisma",
          { "glob": "**/*", "input": "apps/user-service/src/generated/prisma", "output": "src/generated/prisma" }
        ]
      }
    },
    "lint": { "executor": "@nx/eslint:lint" },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": { "jestConfig": "apps/user-service/jest.config.ts" }
    }
  }
}
