// Catalog Service data model. Owns the `catalog` database.
generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Outbox {
  id            String   @id @default(uuid())
  aggregateType String   @map("aggregate_type")
  aggregateId   String   @map("aggregate_id")
  eventType     String   @map("event_type")
  payload       Json
  traceparent   String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([aggregateType, aggregateId])
  @@map("outbox")
}

model ProcessedEvent {
  eventId     String   @id @map("event_id")
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("processed_events")
}

model IdempotencyRecord {
  key          String   @id
  responseJson Json     @map("response_json")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("idempotency_records")
}

/// Platform-governed category taxonomy (tree).
model Category {
  id        String     @id @default(uuid())
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  name      String
  slug      String     @unique
  path      String // materialized path of slugs, e.g. /grocery/snacks
  sortOrder Int        @default(0) @map("sort_order")
  active    Boolean    @default(true)
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([parentId])
  @@map("category")
}

model Brand {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logoUrl   String?  @map("logo_url")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("brand")
}

/// A sellable product, owned by a store (tenant). Money in integer paise.
model Product {
  id           String           @id @default(uuid())
  storeId      String           @map("store_id")
  categoryId   String?          @map("category_id")
  brandId      String?          @map("brand_id")
  title        String
  description  String?
  hsnCode      String?          @map("hsn_code")
  gstRatePct   Int              @default(0) @map("gst_rate_pct")
  taxInclusive Boolean          @default(false) @map("tax_inclusive")
  status       String           @default("draft") // draft|pending|published|rejected
  images       String[]         @default([])
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @default(now()) @updatedAt @map("updated_at")

  variants ProductVariant[]

  @@index([storeId])
  @@index([status])
  @@map("product")
}

model ProductVariant {
  id            String  @id @default(uuid())
  productId     String  @map("product_id")
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId       String  @map("store_id")
  sku           String  @unique
  attributesJson Json   @default("{}") @map("attributes_json")
  mrpPaise      Int     @map("mrp_paise")
  pricePaise    Int     @map("price_paise")
  active        Boolean @default(true)

  @@index([productId])
  @@index([storeId])
  @@map("product_variant")
}
