{
  "name": "platform-reference",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/platform-reference/src",
  "projectType": "application",
  "tags": ["scope:service", "type:reference"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/platform-reference",
        "main": "apps/platform-reference/src/main.ts",
        "tsConfig": "apps/platform-reference/tsconfig.app.json",
        "assets": [
          "apps/platform-reference/prisma/schema.prisma"
        ]
      }
    },
    "lint": { "executor": "@nx/eslint:lint" },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": { "jestConfig": "apps/platform-reference/jest.config.ts" }
    }
  }
}
