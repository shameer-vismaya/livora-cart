# ──────────────────────────────────────────────────────────────────────────
# Livora Cart — local/dev environment (copy to .env). DO NOT commit real secrets.
# Production values live in deploy/.env.production (see deploy/README.md).
# ──────────────────────────────────────────────────────────────────────────

# --- PostgreSQL ---
POSTGRES_USER=livora
POSTGRES_PASSWORD=livora_dev_pw
POSTGRES_DB=livora
POSTGRES_PORT=5432
# Replication role used by Debezium CDC
POSTGRES_REPL_USER=debezium
POSTGRES_REPL_PASSWORD=debezium_dev_pw

# --- Redis ---
REDIS_PORT=6379

# --- Kafka (KRaft, single node) ---
KAFKA_PORT=9092
# Pre-generated base64 cluster id for KRaft (regenerate for prod: kafka-storage random-uuid)
KAFKA_CLUSTER_ID=Mk3OEYBSD34fcwNTJ2j0Tw
SCHEMA_REGISTRY_PORT=8081

# --- Debezium Connect ---
CONNECT_PORT=8083

# --- OpenSearch ---
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601
OPENSEARCH_JAVA_OPTS="-Xms512m -Xmx512m"

# --- Keycloak ---
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev_pw

# --- Kong API Gateway (DB-less) ---
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=livora
MINIO_ROOT_PASSWORD=livora_dev_pw
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Observability (used by Plan 04) ---
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
TEMPO_PORT=3200

# --- platform-reference service (Plan 03) ---
PLATFORM_REFERENCE_PORT=3000
