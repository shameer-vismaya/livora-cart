# ──────────────────────────────────────────────────────────────────────────
# Livora Cart — PRODUCTION env (copy to deploy/.env.production on the host).
# Generate strong secrets. NEVER commit the real file.
# ──────────────────────────────────────────────────────────────────────────

# --- PostgreSQL ---
POSTGRES_USER=livora
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=livora
POSTGRES_PORT=5432
POSTGRES_REPL_USER=debezium
POSTGRES_REPL_PASSWORD=CHANGE_ME_strong_repl_password

# --- Redis ---
REDIS_PORT=6379

# --- Kafka (KRaft) ---
KAFKA_PORT=9092
# Valid default; regenerate for prod: docker run --rm confluentinc/cp-kafka:7.6.1 kafka-storage random-uuid
KAFKA_CLUSTER_ID=Mk3OEYBSD34fcwNTJ2j0Tw
SCHEMA_REGISTRY_PORT=8081

# --- Debezium Connect ---
CONNECT_PORT=8083

# --- OpenSearch ---
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601
OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g

# --- Keycloak ---
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# --- Kong ---
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001

# --- MinIO ---
MINIO_ROOT_USER=livora
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Observability ---
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
TEMPO_PORT=3200

# --- platform-reference ---
PLATFORM_REFERENCE_PORT=3000

# --- Debezium connector registration (used by register-connector.sh) ---
DEBEZIUM_DB_USER=debezium
DEBEZIUM_DB_PASSWORD=CHANGE_ME_strong_repl_password
DEBEZIUM_DB_NAME=livora

# --- Remote deploy (optional; used by deploy.sh --remote) ---
DEPLOY_HOST=your.ubuntu.host
DEPLOY_USER=ubuntu
DEPLOY_PATH=/opt/livora
