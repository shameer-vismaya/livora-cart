{
  "realm": "livora",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 604800,
  "requiredActions": [
    {
      "alias": "VERIFY_PROFILE",
      "name": "Verify Profile",
      "providerId": "VERIFY_PROFILE",
      "enabled": false,
      "defaultAction": false,
      "priority": 90,
      "config": {}
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "customer",
        "description": "Marketplace customer"
      },
      {
        "name": "store_owner",
        "description": "Store owner"
      },
      {
        "name": "store_staff",
        "description": "Store staff (cashier/inventory/manager)"
      },
      {
        "name": "admin",
        "description": "Platform administrator"
      },
      {
        "name": "driver",
        "description": "Delivery driver"
      }
    ]
  },
  "clients": [
    {
      "clientId": "livora-web",
      "name": "Livora Customer Web/App (public)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "*"
      ],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "stores",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "stores",
            "claim.name": "stores",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "livora-store-portal",
      "name": "Livora Store Owner Portal (public)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "*"
      ],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "stores",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "stores",
            "claim.name": "stores",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "livora-admin-portal",
      "name": "Livora Admin Portal (public)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "*"
      ],
      "protocol": "openid-connect"
    },
    {
      "clientId": "identity-admin",
      "name": "Identity Service (confidential, service account)",
      "enabled": true,
      "publicClient": false,
      "secret": "identity-admin-dev-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect"
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "config": {
        "clientId": "REPLACE_WITH_GOOGLE_CLIENT_ID",
        "clientSecret": "REPLACE_WITH_GOOGLE_CLIENT_SECRET",
        "syncMode": "IMPORT"
      }
    }
  ],
  "users": [
    {
      "username": "service-account-identity-admin",
      "enabled": true,
      "serviceAccountClientId": "identity-admin",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users",
          "query-users",
          "view-realm"
        ]
      }
    },
    {
      "username": "testcustomer",
      "enabled": true,
      "emailVerified": true,
      "email": "testcustomer@livora.local",
      "firstName": "Test",
      "lastName": "Customer",
      "credentials": [
        {
          "type": "password",
          "value": "test_pw",
          "temporary": false
        }
      ],
      "realmRoles": [
        "customer"
      ]
    },
    {
      "username": "testadmin",
      "enabled": true,
      "emailVerified": true,
      "email": "testadmin@livora.local",
      "firstName": "Test",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin_pw",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    },
    {
      "username": "teststoreowner",
      "enabled": true,
      "emailVerified": true,
      "email": "teststoreowner@livora.local",
      "firstName": "Test",
      "lastName": "Owner",
      "credentials": [
        {
          "type": "password",
          "value": "owner_pw",
          "temporary": false
        }
      ],
      "realmRoles": [
        "store_owner"
      ]
    },
    {
      "username": "teststoreowner2",
      "enabled": true,
      "emailVerified": true,
      "email": "teststoreowner2@livora.local",
      "firstName": "Test",
      "lastName": "Owner2",
      "credentials": [
        {
          "type": "password",
          "value": "owner_pw",
          "temporary": false
        }
      ],
      "realmRoles": [
        "store_owner"
      ]
    }
  ],
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "name": "Declarative User Profile",
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"unmanagedAttributePolicy\":\"ENABLED\",\"attributes\":[{\"name\":\"username\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"email\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"firstName\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"lastName\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}}]}"
          ]
        }
      }
    ]
  }
}
