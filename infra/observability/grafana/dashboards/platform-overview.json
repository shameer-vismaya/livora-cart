{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Livora — Platform Overview",
  "tags": ["livora"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "panels": [
    {
      "type": "stat",
      "title": "platform-reference up",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"platform-reference\"}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count[5m])) by (http_route)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p95 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Node.js heap used (bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "livora_nodejs_heap_size_used_bytes", "refId": "A" }
      ]
    }
  ]
}
